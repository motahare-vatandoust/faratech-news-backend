# =============================================================================
# faratech-news-backend
# Local development OR Docker (see deployment/.env.example for compose)
# =============================================================================

# Docker Compose (service hostname "postgres" on the faratech bridge network):
# DATABASE_URL=postgresql+psycopg://faratech:CHANGE_ME@postgres:5432/faratech_news
#
# Local macOS (Homebrew):
# DATABASE_URL=postgresql+psycopg://mac@localhost:5432/faratech_news
#
# Bare-metal / shared role:
DATABASE_URL=postgresql+psycopg://faratech:CHANGE_ME@localhost:5432/faratech_news

# Comma-separated browser origins (production sites).
# Localhost (3000 / 5173 / 5174) is always allowed by the app for local frontend work.
CORS_ORIGINS=https://faratech.news,https://www.faratech.news,https://admin.faratech.news

GAPGPT_API_KEY=your-gapgpt-api-key-here
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_DEFAULT_MODEL=gapgpt-qwen-3.6
GAPGPT_TRANSLATION_MODEL=gapgpt-qwen-3.6

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Crawler (optional — DZone uses Cloudflare; curl_cffi helps bypass blocks)
CRAWLER_USE_CURL_CFFI=true
CRAWLER_IMPERSONATE=chrome120
CRAWLER_REQUEST_TIMEOUT=60
CRAWLER_MAX_RETRIES=3
